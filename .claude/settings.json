      "Bash(pnpm test)",
      "Bash(pnpm run:*)",
      "Bash(prettier:*)",
      "Bash(eslint:*)",
      "Bash(claude agents)",
      "Bash(claude plugin list)",
      "Bash(claude plugin marketplace:*)",
      "Bash(claude --version)",
      "Bash(claude --help)",
      "Bash(bash -n:*)",
      "Bash(bash /tmp/*)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git merge:*)",
      "Bash(git revert:*)",
      "Bash(git filter-repo:*)",
      "Bash(git filter-branch:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(npm publish:*)",
      "Bash(pip install:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(uv sync:*)",
      "Bash(npm install:*)",
      "Bash(pnpm install:*)",
      "Bash(npm uninstall:*)",
